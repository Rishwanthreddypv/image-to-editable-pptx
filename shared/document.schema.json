{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EditableLayeredDocument",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "metadata": {
      "type": "object",
      "properties": {
        "width": { "type": "number" },
        "height": { "type": "number" }
      }
    },
    "layers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["text", "table", "figure", "image"] },
          "geometry": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "w": { "type": "number" },
              "h": { "type": "number" }
            }
          },
          "content": { "type": "object" }
        }
      }
    }
  }
}
